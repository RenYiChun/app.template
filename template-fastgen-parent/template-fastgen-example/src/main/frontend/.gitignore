# Logs
*.log
npm-debug.log*

# Dependencies
node_modules/
dist/
dist-ssr/

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Env
.env
.env.local

# ========================================
# Fastgen 自动生成的文件（运行时生成，不提交）
# ========================================

# 生成的 Vue 组件（保留 Home.vue，其他都是生成的）
src/views/*
!src/views/Home.vue
!src/views/.gitkeep

# 生成的 API 服务
src/api/*
!src/api/.gitkeep

# 生成的 TypeScript 类型
src/types/*
!src/types/.gitkeep
