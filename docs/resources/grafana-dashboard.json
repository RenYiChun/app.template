{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "选择 Prometheus 数据源",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 200,
      "title": "应用概览",
      "type": "row",
      "description": "应用基础指标"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "应用整体请求吞吐量。",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "id": 202,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "请求 QPS",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{instance=~\"$instance\",job=\"$job\"}[1m]))",
          "refId": "A",
          "legendFormat": "QPS"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "当前存活的 Java 线程总数。",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "id": 203,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "活跃线程",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jvm_threads_live_threads{instance=~\"$instance\",job=\"$job\"}",
          "refId": "A",
          "legendFormat": "线程"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "已用堆内存 / 最大堆内存。",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "id": 204,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "堆内存使用率",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{instance=~\"$instance\",job=\"$job\",area=\"heap\"}) / sum(jvm_memory_max_bytes{instance=~\"$instance\",job=\"$job\",area=\"heap\"})",
          "refId": "A",
          "legendFormat": "Heap"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "当前进程 CPU 使用率。",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "id": 205,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "CPU 使用率",
      "type": "timeseries",
      "targets": [
        {
          "expr": "process_cpu_usage{instance=~\"$instance\",job=\"$job\"}",
          "refId": "A",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "id": 300,
      "title": "Flow 全局概览",
      "type": "row",
      "description": "全局流量、存储与错误。",
      "panels": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "description": "按 sourceType 统计每秒接收条数。",
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "gridPos": {
            "x": 0,
            "y": 8,
            "w": 6,
            "h": 6
          },
          "id": 301,
          "options": {
            "tooltip": {
              "mode": "multi"
            }
          },
          "title": "Source 输入速率",
          "type": "timeseries",
          "targets": [
            {
              "expr": "sum by (sourceType) (rate(app_template_source_received_total{instance=~\"$instance\",job=\"$job\"}[1m]))",
              "refId": "A",
              "legendFormat": "{{sourceType}}"
            }
          ]
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "description": "全局入口、入库、终结速率。",
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "gridPos": {
            "x": 6,
            "y": 8,
            "w": 6,
            "h": 6
          },
          "id": 302,
          "options": {
            "tooltip": {
              "mode": "multi"
            }
          },
          "title": "主吞吐（进入/入库/终结）",
          "type": "timeseries",
          "targets": [
            {
              "expr": "sum(rate(app_template_flow_production_acquired_total{instance=~\"$instance\",job=\"$job\"}[1m]))",
              "refId": "A",
              "legendFormat": "进入"
            },
            {
              "expr": "sum(rate(app_template_flow_production_released_total{instance=~\"$instance\",job=\"$job\"}[1m]))",
              "refId": "B",
              "legendFormat": "入库"
            },
            {
              "expr": "sum(rate(app_template_flow_terminated_total{instance=~\"$instance\",job=\"$job\"}[1m]))",
              "refId": "C",
              "legendFormat": "终结"
            }
          ]
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "description": "全局 storage 使用量与上限。",
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "gridPos": {
            "x": 12,
            "y": 8,
            "w": 6,
            "h": 6
          },
          "id": 303,
          "options": {
            "tooltip": {
              "mode": "multi"
            }
          },
          "title": "全局 Storage",
          "type": "timeseries",
          "targets": [
            {
              "expr": "sum(app_template_flow_resources_storage_limit{instance=~\"$instance\",job=\"$job\"})",
              "refId": "A",
              "legendFormat": "上限"
            },
            {
              "expr": "sum(app_template_flow_resources_storage_used{instance=~\"$instance\",job=\"$job\"})",
              "refId": "B",
              "legendFormat": "使用"
            }
          ]
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "description": "按 phase/errorType 观察错误。",
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "gridPos": {
            "x": 18,
            "y": 8,
            "w": 6,
            "h": 6
          },
          "id": 304,
          "options": {
            "tooltip": {
              "mode": "multi"
            }
          },
          "title": "Flow 错误率",
          "type": "timeseries",
          "targets": [
            {
              "expr": "sum by (phase) (rate(app_template_flow_errors_total{instance=~\"$instance\",job=\"$job\"}[1m]))",
              "refId": "A",
              "legendFormat": "{{phase}}"
            },
            {
              "expr": "sum by (errorType) (rate(app_template_flow_errors_total{instance=~\"$instance\",job=\"$job\"}[1m]))",
              "refId": "B",
              "legendFormat": "{{errorType}}"
            }
          ]
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 900,
      "title": "Flow 根任务总览",
      "type": "row",
      "description": "根任务视角：查看 rootJobId 的吞吐、错误和总 backlog。",
      "panels": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "description": "按 rootJobId 聚合进入速率与终结 TPS。",
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "gridPos": {
            "x": 0,
            "y": 22,
            "w": 8,
            "h": 6
          },
          "id": 903,
          "options": {
            "tooltip": {
              "mode": "multi"
            }
          },
          "title": "根任务吞吐（进入/终结）",
          "type": "timeseries",
          "targets": [
            {
              "expr": "sum by (rootJobDisplayName, rootJobId) (rate(app_template_flow_production_acquired_total{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\"}[1m]))",
              "refId": "A",
              "legendFormat": "进入 {{rootJobDisplayName}}"
            },
            {
              "expr": "sum by (rootJobDisplayName, rootJobId) (rate(app_template_flow_terminated_total{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\"}[1m]))",
              "refId": "B",
              "legendFormat": "终结 {{rootJobDisplayName}}"
            }
          ]
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "description": "按 rootJobId 聚合错误率。",
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "gridPos": {
            "x": 8,
            "y": 22,
            "w": 8,
            "h": 6
          },
          "id": 904,
          "options": {
            "tooltip": {
              "mode": "multi"
            }
          },
          "title": "根任务错误率",
          "type": "timeseries",
          "targets": [
            {
              "expr": "sum by (rootJobDisplayName, rootJobId, errorType) (rate(app_template_flow_errors_total{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\"}[1m]))",
              "refId": "A",
              "legendFormat": "{{rootJobDisplayName}} {{errorType}}"
            }
          ]
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "description": "按 rootJobId 聚合所有 stage backlog。",
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "gridPos": {
            "x": 16,
            "y": 22,
            "w": 8,
            "h": 6
          },
          "id": 905,
          "options": {
            "tooltip": {
              "mode": "multi"
            }
          },
          "title": "根任务总 Storage",
          "type": "timeseries",
          "targets": [
            {
              "expr": "sum by (rootJobDisplayName, rootJobId) (app_template_flow_resources_per_job_storage_used{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\"})",
              "refId": "A",
              "legendFormat": "{{rootJobDisplayName}}"
            }
          ]
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "id": 910,
      "title": "Flow 阶段下钻",
      "type": "row",
      "description": "阶段视角：按 rootJobId + stageKey 查看 TPS、Storage、ActiveConsumers 和完成水位。"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "按阶段查看进入与终结 TPS。",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 6,
        "h": 6
      },
      "id": 913,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "阶段 TPS",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (stageKey, stageDisplayName) (rate(app_template_flow_production_acquired_total{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"}[1m]))",
          "refId": "A",
          "legendFormat": "进入 {{stageDisplayName}}"
        },
        {
          "expr": "sum by (stageKey, stageDisplayName) (rate(app_template_flow_terminated_total{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"}[1m]))",
          "refId": "B",
          "legendFormat": "终结 {{stageDisplayName}}"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "阶段 Storage 上限与使用量。",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "x": 6,
        "y": 36,
        "w": 6,
        "h": 6
      },
      "id": 914,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "阶段 Storage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (stageKey, stageDisplayName) (app_template_flow_resources_per_job_storage_limit{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"})",
          "refId": "A",
          "legendFormat": "上限 {{stageDisplayName}}"
        },
        {
          "expr": "sum by (stageKey, stageDisplayName) (app_template_flow_resources_per_job_storage_used{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"})",
          "refId": "B",
          "legendFormat": "使用 {{stageDisplayName}}"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "阶段 ActiveConsumers 上限与使用量。",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 6,
        "h": 6
      },
      "id": 919,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "阶段 ActiveConsumers",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (stageKey, stageDisplayName) (app_template_flow_resources_per_job_active_consumers_limit{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"})",
          "refId": "A",
          "legendFormat": "上限 {{stageDisplayName}}"
        },
        {
          "expr": "sum by (stageKey, stageDisplayName) (app_template_flow_completion_active_consumers{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"})",
          "refId": "B",
          "legendFormat": "使用 {{stageDisplayName}}"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Deposit / Match / Finalize 的 P99。",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "x": 18,
        "y": 36,
        "w": 6,
        "h": 6
      },
      "id": 915,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "阶段耗时（P99）",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(app_template_flow_deposit_duration_seconds_bucket{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"}[1m])) by (le, stageKey, stageDisplayName))",
          "refId": "A",
          "legendFormat": "Deposit {{stageDisplayName}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(app_template_flow_match_duration_seconds_bucket{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"}[1m])) by (le, stageKey, stageDisplayName))",
          "refId": "B",
          "legendFormat": "Match {{stageDisplayName}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(app_template_flow_finalize_duration_seconds_bucket{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"}[1m])) by (le, stageKey, stageDisplayName))",
          "refId": "C",
          "legendFormat": "Finalize {{stageDisplayName}}"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "未完成阶段数：总阶段数减去已 source finished 的阶段数。",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 6,
        "h": 4
      },
      "id": 916,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "title": "SourceUnfinished",
      "type": "stat",
      "targets": [
        {
          "expr": "clamp_min((((count(app_template_flow_stage_start_time_seconds{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"})) or on() vector(0)) - ((sum(app_template_flow_completion_source_finished{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"})) or on() vector(0))), 0)",
          "refId": "A",
          "legendFormat": "__auto",
          "instant": true
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "原始完成水位：当前阶段 storage 使用量。",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "x": 6,
        "y": 42,
        "w": 6,
        "h": 4
      },
      "id": 917,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "title": "StorageUsed",
      "type": "stat",
      "targets": [
        {
          "expr": "(sum(app_template_flow_resources_per_job_storage_used{instance=~\"$instance\",job=\"$job\",rootJobId=~\"$rootJobId\",stageKey=~\"$stageKey\"})) or on() vector(0)",
          "refId": "A",
          "legendFormat": "__auto",
          "instant": true
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "原始完成水位：当前阶段活跃消费数。",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
