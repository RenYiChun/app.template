{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "选择 Prometheus 数据源",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "应用概览",
      "type": "row",
      "panels": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "description": "HTTP 请求 QPS：每秒处理的 HTTP 请求总数，反映应用整体请求吞吐量。", "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }, "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 }, "id": 202, "options": { "tooltip": { "mode": "multi" } }, "title": "HTTP 请求 QPS（每秒请求数）", "type": "timeseries", "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{instance=~\"$instance\",job=\"$job\"}[1m]))", "refId": "A" }] },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "description": "HTTP 平均响应时间：所有请求的平均耗时（秒），用于评估接口整体响应速度。", "fieldConfig": { "defaults": { "unit": "s", "decimals": 3, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }, "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 }, "id": 203, "options": { "tooltip": { "mode": "multi" } }, "title": "HTTP 平均响应时间（秒）", "type": "timeseries", "targets": [{ "expr": "sum(rate(http_server_requests_seconds_sum{instance=~\"$instance\",job=\"$job\"}[1m])) / sum(rate(http_server_requests_seconds_count{instance=~\"$instance\",job=\"$job\"}[1m]))", "refId": "A" }] },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "description": "HTTP 响应时间分位数：P99（99% 请求低于该值）、P95、P50（中位数），用于发现长尾延迟。", "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }, "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 }, "id": 210, "options": { "tooltip": { "mode": "multi" } }, "title": "HTTP 响应时间分位数（P99/P95/P50，秒）", "type": "timeseries", "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{instance=~\"$instance\",job=\"$job\"}[1m])) by (le))", "legendFormat": "P99", "refId": "A" }, { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{instance=~\"$instance\",job=\"$job\"}[1m])) by (le))", "legendFormat": "P95", "refId": "B" }, { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{instance=~\"$instance\",job=\"$job\"}[1m])) by (le))", "legendFormat": "P50", "refId": "C" }] },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "description": "JVM 活跃线程数：当前存活的 Java 线程总数，用于监控线程泄漏或过高并发。", "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }, "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 }, "id": 206, "options": { "tooltip": { "mode": "multi" } }, "title": "JVM 活跃线程数", "type": "timeseries", "targets": [{ "expr": "jvm_threads_live_threads{instance=~\"$instance\",job=\"$job\"}", "refId": "A" }] },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "description": "CPU 使用率：系统整体 CPU 占用与当前 JVM 进程 CPU 占用（0–1 表示 0%–100%）。", "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }, "gridPos": { "x": 0, "y": 6, "w": 6, "h": 6 }, "id": 209, "options": { "tooltip": { "mode": "multi" } }, "title": "CPU 使用率（系统/进程）", "type": "timeseries", "targets": [{ "expr": "system_cpu_usage{instance=~\"$instance\",job=\"$job\"}", "legendFormat": "系统", "refId": "A" }, { "expr": "process_cpu_usage{instance=~\"$instance\",job=\"$job\"}", "legendFormat": "进程", "refId": "B" }] },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "description": "JVM 堆内存使用率：已用堆内存 / 最大堆内存，接近 1 时需关注 GC 或扩容。", "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }, "gridPos": { "x": 6, "y": 6, "w": 6, "h": 6 }, "id": 204, "options": { "tooltip": { "mode": "multi" } }, "title": "JVM 堆内存使用率（已用/最大）", "type": "timeseries", "targets": [{ "expr": "sum(jvm_memory_used_bytes{instance=~\"$instance\",job=\"$job\",area=\"heap\"}) / sum(jvm_memory_max_bytes{instance=~\"$instance\",job=\"$job\",area=\"heap\"})", "refId": "A" }] },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "description": "JVM 内存占用：按区域（heap 堆 / nonheap 非堆）展示已用与最大字节数，用于排查内存问题。", "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }, "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 }, "id": 208, "options": { "tooltip": { "mode": "multi" } }, "title": "JVM 内存占用（按区域：heap/nonheap）", "type": "timeseries", "targets": [{ "expr": "sum by (area) (jvm_memory_used_bytes{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "已用 {{area}}", "refId": "A" }, { "expr": "sum by (area) (jvm_memory_max_bytes{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "最大 {{area}}", "refId": "B" }] }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 1 },
      "id": 120,
      "title": "Flow 引擎概览（global）",
      "type": "row",
      "panels": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "背压 生产在途数：已 acquire 未 release 的 launch 数量。上限为配置值，使用为当前占用。使用接近上限表示生产端可能被限流。",
          "fieldConfig": {
            "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
            "overrides": []
          },
          "gridPos": { "x": 0, "y": 0, "w": 5, "h": 6 },
          "id": 360,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "生产在途数（已 acquire 未 release 的 launch 数，上限/使用）",
          "type": "timeseries",
          "targets": [
            { "expr": "sum(app_template_flow_resources_in_flight_production_limit{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "上限", "refId": "A" },
            { "expr": "sum(app_template_flow_resources_in_flight_production_used{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "使用", "refId": "B" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "背压 生产线程数：deposit 任务的并发线程数。上限为配置值，使用为当前活跃数。使用接近上限表示生产端已满负荷。",
          "fieldConfig": {
            "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
            "overrides": []
          },
          "gridPos": { "x": 5, "y": 0, "w": 5, "h": 6 },
          "id": 361,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "生产线程数（deposit 任务并发，上限/使用）",
          "type": "timeseries",
          "targets": [
            { "expr": "sum(app_template_flow_resources_producer_threads_limit{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "上限", "refId": "A" },
            { "expr": "sum(app_template_flow_resources_producer_threads_used{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "使用", "refId": "B" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "背压 存储容量：Flow 缓存中的条目数。上限为配置值，使用为当前缓存条数。使用接近上限表示存储可能成为瓶颈。",
          "fieldConfig": {
            "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
            "overrides": []
          },
          "gridPos": { "x": 10, "y": 0, "w": 5, "h": 6 },
          "id": 362,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "存储容量（缓存条目数，上限/使用）",
          "type": "timeseries",
          "targets": [
            { "expr": "sum(app_template_flow_resources_storage_limit{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "上限", "refId": "A" },
            { "expr": "sum(app_template_flow_resources_storage_used{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "使用", "refId": "B" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "背压 在途消费数：已离库但未消费的条目数（onSingleConsumed/onPairConsumed 回调执行中）。使用接近上限表示消费端可能被限流。",
          "fieldConfig": {
            "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
            "overrides": []
          },
          "gridPos": { "x": 15, "y": 0, "w": 5, "h": 6 },
          "id": 363,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "在途消费数（已离库未消费条数，上限/使用）",
          "type": "timeseries",
          "targets": [
            { "expr": "sum(app_template_flow_resources_in_flight_consumer_limit{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "上限", "refId": "A" },
            { "expr": "sum(app_template_flow_resources_in_flight_consumer_used{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "使用", "refId": "B" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "背压 消费线程数：onSingleConsumed/onPairConsumed 回调的并发线程数。使用接近上限表示消费端已满负荷。",
          "fieldConfig": {
            "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
            "overrides": []
          },
          "gridPos": { "x": 20, "y": 0, "w": 4, "h": 6 },
          "id": 364,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "消费线程数（onSingleConsumed/onPairConsumed 并发，上限/使用）",
          "type": "timeseries",
          "targets": [
            { "expr": "sum(app_template_flow_resources_consumer_threads_limit{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "上限", "refId": "A" },
            { "expr": "sum(app_template_flow_resources_consumer_threads_used{instance=~\"$instance\",job=\"$job\"})", "legendFormat": "使用", "refId": "B" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "Flow 吞吐量：每秒成功终结（terminated）的条目数，反映 Flow 引擎的实际产出速率。获取在途生产许可：InFlightProductionDimension 每秒成功获取的许可数（attempts - timeout）。",
          "fieldConfig": {
            "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
            "overrides": []
          },
          "gridPos": { "x": 0, "y": 6, "w": 6, "h": 6 },
          "id": 301,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "Flow 吞吐量（条数/秒）",
          "type": "timeseries",
          "targets": [
            { "expr": "sum(rate(app_template_flow_terminated_total{instance=~\"$instance\",job=\"$job\"}[1m]))", "legendFormat": "终结", "refId": "A" },
            { "expr": "sum(rate(backpressure_dimension_acquire_attempts_total{instance=~\"$instance\",job=\"$job\",dimensionId=\"in-flight-production\"}[1m])) - sum(rate(backpressure_dimension_acquire_timeout_total{instance=~\"$instance\",job=\"$job\",dimensionId=\"in-flight-production\"}[1m]))", "legendFormat": "获取在途生产许可", "refId": "B" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "Flow 错误（按阶段）：每秒发生的错误按阶段分类。PRODUCTION=生产、STORAGE=存储、CONSUMPTION=消费、FINALIZATION=终结。",
          "fieldConfig": {
            "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "normal" } } },
            "overrides": []
          },
          "gridPos": { "x": 6, "y": 6, "w": 6, "h": 6 },
          "id": 302,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "Flow 错误（按阶段：PRODUCTION/STORAGE/CONSUMPTION/FINALIZATION）",
          "type": "timeseries",
          "targets": [{ "expr": "sum by (phase) (rate(app_template_flow_errors_total{instance=~\"$instance\",job=\"$job\"}[1m]))", "legendFormat": "{{phase}}", "refId": "A" }]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "Flow 错误（按类型）：每秒发生的错误按 errorType 分类，如 job_failed、deposit_failed、match_failed、finalize_failed 等。",
          "fieldConfig": {
            "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "normal" } } },
            "overrides": []
          },
          "gridPos": { "x": 12, "y": 6, "w": 6, "h": 6 },
          "id": 303,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "Flow 错误（按类型：job_failed/deposit_failed 等）",
          "type": "timeseries",
          "targets": [{ "expr": "sum by (errorType) (rate(app_template_flow_errors_total{instance=~\"$instance\",job=\"$job\"}[1m]))", "legendFormat": "{{errorType}}", "refId": "A" }]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "背压许可获取：每秒成功获取背压许可的次数与失败次数。失败增多表示资源紧张或配置过严。",
          "fieldConfig": {
            "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
            "overrides": []
          },
          "gridPos": { "x": 18, "y": 6, "w": 6, "h": 6 },
          "id": 311,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "许可获取（成功/失败次数每秒）",
          "type": "timeseries",
          "targets": [
            { "expr": "sum(rate(backpressure_manager_acquire_success_total{instance=~\"$instance\",job=\"$job\"}[1m]))", "legendFormat": "成功", "refId": "A" },
            { "expr": "sum(rate(backpressure_manager_acquire_failed_total{instance=~\"$instance\",job=\"$job\"}[1m]))", "legendFormat": "失败", "refId": "B" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "Flow 各阶段耗时：Deposit（入库）、Match（配对）、Finalize（终结）的 P99 延迟（秒）。超时曲线为背压获取超时次数/秒。",
          "fieldConfig": {
            "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
            "overrides": [
              { "matcher": { "id": "byRegexp", "options": "超时.*" }, "properties": [{ "id": "unit", "value": "ops" }] }
            ]
          },
          "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
          "id": 314,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "Flow 各阶段耗时（Deposit/Match/Finalize P99）及超时",
          "type": "timeseries",
          "targets": [
            { "expr": "histogram_quantile(0.99, sum(rate(app_template_flow_deposit_duration_seconds_bucket{instance=~\"$instance\",job=\"$job\"}[1m])) by (le))", "legendFormat": "Deposit P99", "refId": "A" },
            { "expr": "histogram_quantile(0.99, sum(rate(app_template_flow_match_duration_seconds_bucket{instance=~\"$instance\",job=\"$job\"}[1m])) by (le))", "legendFormat": "Match P99", "refId": "B" },
            { "expr": "histogram_quantile(0.99, sum(rate(app_template_flow_finalize_duration_seconds_bucket{instance=~\"$instance\",job=\"$job\"}[1m])) by (le))", "legendFormat": "Finalize P99", "refId": "C" },
            { "expr": "sum by (dimensionId) (rate(backpressure_dimension_acquire_timeout_total{instance=~\"$instance\",job=\"$job\"}[1m]))", "legendFormat": "超时 {{dimensionId}}", "refId": "D" },
            { "expr": "histogram_quantile(0.99, sum by (le, method) (rate(app_template_dataforge_request_duration_seconds_bucket{instance=~\"$instance\",job=\"$job\"}[1m])))", "legendFormat": "Dataforge {{method}} P99", "refId": "E" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "背压维度 in-flight-production / in-flight-consumer：尝试次数（每秒获取许可的尝试）、阻塞次数（因资源不足等待）、超时次数、获取耗时P99（秒）",
          "fieldConfig": {
            "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
            "overrides": [
              { "matcher": { "id": "byRegexp", "options": ".*耗时.*" }, "properties": [{ "id": "unit", "value": "s" }] }
            ]
          },
          "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
          "id": 350,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "in-flight 维度（生产在途/消费在途：尝试、阻塞、超时、耗时）",
          "type": "timeseries",
          "targets": [
            { "expr": "sum by (dimensionId) (rate(backpressure_dimension_acquire_attempts_total{instance=~\"$instance\",job=\"$job\",dimensionId=~\"in-flight-production|in-flight-consumer\"}[1m]))", "legendFormat": "尝试次数 {{dimensionId}}", "refId": "A" },
            { "expr": "sum by (dimensionId) (rate(backpressure_dimension_acquire_blocked_total{instance=~\"$instance\",job=\"$job\",dimensionId=~\"in-flight-production|in-flight-consumer\"}[1m]))", "legendFormat": "阻塞次数 {{dimensionId}}", "refId": "B" },
            { "expr": "sum by (dimensionId) (rate(backpressure_dimension_acquire_timeout_total{instance=~\"$instance\",job=\"$job\",dimensionId=~\"in-flight-production|in-flight-consumer\"}[1m]))", "legendFormat": "超时次数 {{dimensionId}}", "refId": "C" },
            { "expr": "histogram_quantile(0.99, sum(rate(backpressure_dimension_acquire_duration_seconds_bucket{instance=~\"$instance\",job=\"$job\",dimensionId=~\"in-flight-production|in-flight-consumer\"}[1m])) by (le, dimensionId))", "legendFormat": "获取耗时P99 {{dimensionId}}", "refId": "D" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "背压维度 producer-concurrency / consumer-concurrency：尝试次数（每秒获取生产/消费线程许可的尝试）、阻塞次数（因资源不足等待）、超时次数、获取耗时P99（秒）",
          "fieldConfig": {
            "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
            "overrides": [
              { "matcher": { "id": "byRegexp", "options": ".*耗时.*" }, "properties": [{ "id": "unit", "value": "s" }] }
            ]
          },
          "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 },
          "id": 351,
          "options": { "tooltip": { "mode": "multi" } },
          "title": "producer/consumer 维度（生产/消费线程：尝试、阻塞、超时、耗时）",
          "type": "timeseries",
          "targets": [
            { "expr": "sum by (dimensionId) (rate(backpressure_dimension_acquire_attempts_total{instance=~\"$instance\",job=\"$job\",dimensionId=~\"producer-concurrency|consumer-concurrency\"}[1m]))", "legendFormat": "尝试次数 {{dimensionId}}", "refId": "A" },
            { "expr": "sum by (dimensionId) (rate(backpressure_dimension_acquire_blocked_total{instance=~\"$instance\",job=\"$job\",dimensionId=~\"producer-concurrency|consumer-concurrency\"}[1m]))", "legendFormat": "阻塞次数 {{dimensionId}}", "refId": "B" },
            { "expr": "sum by (dimensionId) (rate(backpressure_dimension_acquire_timeout_total{instance=~\"$instance\",job=\"$job\",dimensionId=~\"producer-concurrency|consumer-concurrency\"}[1m]))", "legendFormat": "超时次数 {{dimensionId}}", "refId": "C" },
            { "expr": "histogram_quantile(0.99, sum(rate(backpressure_dimension_acquire_duration_seconds_bucket{instance=~\"$instance\",job=\"$job\",dimensionId=~\"producer-concurrency|consumer-concurrency\"}[1m])) by (le, dimensionId))", "legendFormat": "获取耗时P99 {{dimensionId}}", "refId": "D" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "背压维度 storage：尝试次数（每秒获取存储许可的尝试）、阻塞次数（因存储满等待）、超时次数、获取耗时P99（秒）",
          "fieldConfig": {
