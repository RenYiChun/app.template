<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="https://github.com/spotbugs/filter/4.8.4"
        xsi:schemaLocation="https://github.com/spotbugs/filter/4.8.4 https://raw.githubusercontent.com/spotbugs/spotbugs/4.8.4/spotbugs/etc/findbugsfilter.xsd">

    <!-- 策略：全量运行 SpotBugs + FindSecBugs，仅在此排除误报或已接受的项。 -->

    <!-- 低置信度告警（减少噪音） -->
    <Match>
        <Confidence value="3"/>
    </Match>

    <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2：配置类、DTO、框架内部 getter/setter 返回或接收可变引用，项目内接受 -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2,EI_EXPOSE_STATIC_REP2"/>
    </Match>

    <!-- MS_EXPOSE_REP：单例等返回静态可变引用，项目内接受 -->
    <Match>
        <Bug code="MS"/>
    </Match>

    <!-- VA_FORMAT_STRING_USES_NEWLINE：格式串使用 \n 而非 %n，风格类 -->
    <Match>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
    </Match>

    <!-- RCN_REDUNDANT_NULLCHECK：冗余 null 检查，常为误报 -->
    <Match>
        <Bug code="RCN"/>
    </Match>

    <!-- DM_DEFAULT_ENCODING：依赖默认编码（如 FileWriter、String(byte[])），待后续按需修复 -->
    <Match>
        <Bug pattern="DM_DEFAULT_ENCODING"/>
    </Match>

    <!-- PATH_TRAVERSAL_OUT：FindSecBugs 路径遍历告警，RsaUtils 等写文件场景已接受 -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_OUT"/>
    </Match>

    <!-- PATH_TRAVERSAL_IN：RsaUtils.convert*KeyToPem 已通过 validateAndResolvePath 校验路径 -->
    <Match>
        <Class name="com.lrenyi.template.core.util.RsaUtils"/>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
    </Match>

    <!-- SPRING_CSRF_UNRESTRICTED_REQUEST_MAPPING：REST API 使用 Bearer token，非 Cookie 鉴权，CSRF 不适用 -->
    <Match>
        <Class name="com.lrenyi.template.dataforge.controller.GenericEntityController"/>
        <Bug pattern="SPRING_CSRF_UNRESTRICTED_REQUEST_MAPPING"/>
    </Match>

    <!-- DLS_DEAD_LOCAL_STORE / UC_USELESS_OBJECT：死存储、无用对象，多为风格或待重构 -->
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE,UC_USELESS_OBJECT"/>
    </Match>

    <!-- NP 相关：非空参数违反、可能 NPE 路径，部分为误报或待后续加固 -->
    <Match>
        <Bug pattern="NP_NONNULL_PARAM_VIOLATION,NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>

    <!-- NP_NONNULL_RETURN_VIOLATION：已正确标注 @Nullable，SpotBugs 不识别 jspecify 注解 -->
    <Match>
        <Bug pattern="NP_NONNULL_RETURN_VIOLATION"/>
    </Match>
</FindBugsFilter>
